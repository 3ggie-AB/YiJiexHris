GROQ_API_KEY=<SECRET>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
# Opsional. Model khusus tahap analyze agar berbeda dari model default lain.
GROQ_ANALYSIS_MODEL=<analysis-model-on-groq>
# Maksimum budget request Groq untuk tahap analyze multi-pass.
GROQ_ANALYSIS_MAX_REQUESTS=40

# Pisahkan dengan koma, titik koma, atau baris baru.
PROJECT_REPOS=D:/project1;D:/project2
PROJECTS_BASE_DIRS=D:/projects
DISCOVERY_IGNORE_NAMES=.git,node_modules,dist,build,.next,.turbo
PROJECT_PREVIEW_URLS_JSON={}
PROJECT_RUN_COMMANDS_JSON={}
PROJECT_ALIASES_JSON={}
# Opsional. Kosongkan kalau mau route dianalisa otomatis dari file yang berubah dan routes/*.php
PROJECT_ROUTE_RULES_JSON={}
# Opsional. Dipakai kalau halaman project harus login dulu sebelum screenshot.
PROJECT_WEB_AUTH_JSON={}

HRIS_LOGIN_URL=https://hr.itsyntax.dev/api/login
HRIS_CARDS_URL=https://hr.itsyntax.dev/api/cards
HRIS_API_METHOD=POST
HRIS_EMAIL=
HRIS_PASSWORD=
HRIS_LIST_ID=
HRIS_BOARD_ID=
HRIS_BOARD_LISTS_URL=
HRIS_CARD_LIMIT=50
HRIS_API_TOKEN=
HRIS_AUTH_HEADER=Authorization
HRIS_TOKEN_PREFIX=Bearer
HRIS_API_HEADERS_JSON={}
HRIS_PAYLOAD_STATIC_JSON={}
HRIS_CARD_CHECKLISTS_JSON=[{"id":487573,"title":"Progres","checklist":"yes","position":1},{"id":487574,"title":"Bukti","checklist":"yes","position":2},{"id":487575,"title":"Final","checklist":"yes","position":3}]
HRIS_SEND_DESCRIPTION=true
HRIS_SEND_EVIDENCE=true
HRIS_EVIDENCE_MODE=auto
HRIS_EVIDENCE_DIR=./reports/evidence
HRIS_BROWSER_PATH=
HRIS_DEV_SERVER_WAIT_MS=12000
HRIS_EMPLOYEE_ID=EMP-001

OUTPUT_DIR=./reports
MAX_COMMITS_PER_REPO=15
MAX_FILES_PER_REPO=30
ANALYSIS_MIN_FILE_CHANGE_COUNT=2
ANALYSIS_MIN_UNIT_CHANGE_COUNT=8

# Dipakai oleh command `bun run schedule`, berbasis jam lokal mesin.
SCHEDULE_TIME=22:00
SCHEDULE_RUN_ON_START=true
